{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api",
      "destination": "https://ys-store-h1ec.onrender.com/api"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://ys-store-h1ec.onrender.com/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
